# Database — matches docker-compose.yml defaults
DATABASE_URL=postgresql://orch:orch@localhost:5433/ai_orchestrator

# API
API_PORT=3010
API_SECRET=changeme

# Routing — ANTHROPIC_API_KEY enables Claude fallback; omit for rules-only routing
ANTHROPIC_API_KEY=
ROUTING_MODEL=claude-haiku-4-5-20251001
TASK_POLL_MS=15000

# Agent identity — set these after registering an agent via the dashboard or CLI
AGENT_ID=
PROJECT_ID=

# MCP server transport: stdio (default) or http
TRANSPORT=stdio
MCP_PORT=3001

# Self-hosted orchestrator daemon (optional — only needed if not using the built-in scheduler)
ORCHESTRATOR_API_URL=http://localhost:3010
ORCHESTRATOR_API_SECRET=   # same as API_SECRET
