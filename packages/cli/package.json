{
  "name": "@getrelai/cli",
  "version": "0.1.0",
  "description": "CLI for relai — register agents, manage tasks, exchange messages, and coordinate work across humans and AI agents.",
  "keywords": [
    "relai",
    "agents",
    "ai-agents",
    "claude",
    "claude-code",
    "task-management",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/phillipsio/relai/tree/main/packages/cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phillipsio/relai.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/phillipsio/relai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "relai": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "rm -rf dist && pnpm build"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "@inquirer/prompts": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
