{
  "name": "@getrelai/mcp-server",
  "version": "0.1.0",
  "description": "MCP server for relai — connect any MCP-capable agent (Claude Code, Cursor, Copilot, Windsurf, etc.) to a relai project.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "agents",
    "ai-agents",
    "relai"
  ],
  "license": "MIT",
  "homepage": "https://github.com/phillipsio/relai/tree/main/packages/mcp-server",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/phillipsio/relai.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/phillipsio/relai/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "relai-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "rm -rf dist && pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.6.0",
    "nanoid": "^5.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
